# ═══════════════════════════════════════════════════════════════
# JobNet.co.ke — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
# IMPORTANT: Password special chars must be URL-encoded:
#   @ → %40    % → %25    # → %23    ? → %3F
# ═══════════════════════════════════════════════════════════════

# Database (MySQL) — REQUIRED
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# NextAuth — REQUIRED
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://www.jobready.co.ke"

# Site Config
NEXT_PUBLIC_SITE_URL="https://www.jobready.co.ke"
NEXT_PUBLIC_SITE_DOMAIN="www.jobready.co.ke"

# Google OAuth (optional — for Google Sign-In)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# M-Pesa (optional — for payments)
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_BUSINESS_SHORTCODE=""
MPESA_CALLBACK_URL=""

# Email (optional — for notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# Africa's Talking (optional — for SMS OTPs)
AT_API_KEY=""
AT_USERNAME=""
AT_SENDER=""
