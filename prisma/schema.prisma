// ============================================================
// JobNet.co.ke — Production Database Schema (Prisma + MySQL)
// ============================================================
// Covers all 8 prototypes + Job Seeker Dashboard + M-Pesa Payments
// + SEO + DPA Compliance + Analytics + CMS + Google Jobs
//
// Design Decisions:
//   - Enums stored as String, validated in app code against data.js
//   - Location stored as structured fields (country, county, town) plus display string
//   - No JobCategory table (driven by hub-config.js / org_data.js)
//   - Json type for array fields (MySQL JSON columns)
//   - Nullable userId on orders (walk-in WhatsApp orders)
//   - Nullable userId on reactions (anonymous users via fingerprint)
//   - Partial payment support via paidAmount/balanceDue on orders
//   - Salary fields exist but optional (salaryMin, salaryMax, salaryCurrency, salaryPeriod)
//   - Opportunities linked to Company (optional FK)
//   - socialLinks JSON on Company for dynamic social media profiles
//
// v2 Changes (SEO + Google Jobs):
//   - Job: added publishedAt (CRITICAL for Google Jobs datePosted),
//     featuredImage, industry, viewCount, applicantCount, createdBy
//   - Opportunity: added featuredImage, createdBy;
//     removed: category (merged into opportunityType), provider, value, currency,
//     targetAudience, fieldOfInterest, source, sourceUrl, externalApplyUrl
//   - Company: added size (Google Jobs numberOfEmployees), createdBy (admin who created);
//     removed tagline, removed userId/user owner relation
//   - Education, skills, benefits, qualifications live in description
//     (structured via markdown template — Google parses headings + bullets)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. USERS — Job Seekers
// ============================================================
// Only job seekers register for v1. Admin & employer dashboards
// are separate future projects. Auth handled by NextAuth.js.

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  phone          String?   @unique                    // +2547XXXXXXXX
  googleId       String?   @unique                    // Google OAuth sub (unique identifier)
  name           String
  passwordHash   String?                              // null = OAuth-only user

  // Role
  role           String    @default("JOB_SEEKER")      // "JOB_SEEKER", "EMPLOYER", "ADMIN"

  // Profile
  avatar         String?                              // Avatar URL or color
  bio            String?                              // Short bio
  location       String?                              // "Nairobi, Kenya"
  linkedinUrl    String?
  education      String?                              // Free text
  skills         Json?                                // ["CPA-K", "Excel", "Sage"]
  cvUrl          String?                              // Uploaded CV path

  // Verification
  emailVerified  Boolean   @default(false)
  phoneVerified  Boolean   @default(false)
  lastLoginAt    DateTime?

  // Timestamps
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  authAccounts   AuthAccount[]
  savedJobs      SavedJob[]
  savedArticles  SavedArticle[]
  jobAlerts      JobAlert[]
  reactions      ArticleReaction[]
  notifications  Notification[]
  orders         Order[]
  newsletterSubs NewsletterSubscription[]
  createdCompanies Company[]  @relation("CompanyCreator")
  createdOpportunities Opportunity[]  @relation("OpportunityCreator")
  createdJobs      Job[]      @relation("JobCreator")
  applications   Application[]

  @@map("users")
}

// ============================================================
// 2. AUTH ACCOUNTS — Multi-provider auth
// ============================================================
// Now only used for: Google OAuth token storage, NextAuth compatibility
// Supports: Google OAuth (token storage), NextAuth compatibility
// One user can have multiple auth methods linked

model AuthAccount {
  id               String    @id @default(cuid())
  userId           String?
  user             User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         String                              // "google" | "email" | "phone"
  providerAccountId String   @unique                   // Google sub, phone number, email
  accessToken      String?   @db.Text                    // OAuth token (Google tokens can be very long)
  refreshToken     String?   @db.Text                    // OAuth refresh token
  idToken          String?   @db.Text                    // OpenID token
  expiresAt        DateTime?
  scope            String?   @db.Text                    // OAuth scopes granted
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("auth_accounts")
}

// ============================================================
// 2b. OTPS — One-Time Password Storage
// ============================================================
// Replaces using AuthAccount for OTP. Stores phone OTPs for auth, reset, verify.

model Otp {
  id               String    @id @default(cuid())
  phone            String                      // Target phone number (normalized 2547XXXXXXXX)
  code             String                      // 6-digit OTP
  purpose          String    @default("auth")  // "auth" | "reset" | "verify"
  verified         Boolean   @default(false)   // Whether this OTP was used
  expiresAt        DateTime                    // OTP expiry time
  createdAt        DateTime  @default(now())

  @@index([phone, purpose])    // For lookup: find latest OTP by phone + purpose
  @@map("otps")
}

// ============================================================
// 3. COMPANIES — Employer Organizations
// ============================================================
// Seen in: Homepage (top employers, trusted bar), Job Detail,
// Company Profile page, Search Results sidebar

model Company {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique                    // "safaricom-plc"
  logo            String?                              // Logo URL
  logoColor       String?                              // Fallback gradient "#00a254,#00c853"
  description     String    @db.MediumText             // About section (rich text)
  // Classification
  organizationType String?   @map("organization_type")  // organizationType enum:
                                                // "PRIVATE", "SMALL_BUSINESS", "STARTUP", "NGO",
                                                // "INTERNATIONAL_ORG", "NATIONAL_GOV", "COUNTY_GOV",
                                                // "STATE_CORPORATION", "EDUCATION", "FOUNDATION",
                                                // "RELIGIOUS_ORG"
  industry        String                               // organizationIndustry enum:
                                                // "BANKING", "INFORMATION_TECHNOLOGY", etc. (36 values)
  size            String?                              // companySize enum:
                                                // "1-10", "11-50", "51-200", "201-500",
                                                // "501-1000", "1000+"
                                                // Google Jobs numberOfEmployees

  // Created by (admin user who added this company)
  createdBy       String?
  creator         User?     @relation("CompanyCreator", fields: [createdBy], references: [id])

  // Location
  county          String?                              // "Nairobi" — maps to organizationLocation[].regions[]
  town            String?                              // "Westlands" (manual input for specific area)
  country         String    @default("Kenya")
  website         String?

  // Social links (dynamic — stored as JSON array)
  socialLinks     Json?                                // [{platform: "LINKEDIN", url: "https://..."}, ...]

  // Public contact
  contactEmail    String?                              // Public contact email
  phoneNumber     String?                              // Public phone number

  // Status
  isVerified      Boolean   @default(false)             // Green verified badge
  isFeatured      Boolean   @default(false)             // "Trusted By" section
  isActive        Boolean   @default(true)

  // SEO
  noIndex         Boolean   @default(false)
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // Denormalized counters (updated via triggers/cron)
  jobCount        Int       @default(0)
  opportunityCount Int      @default(0)                 // Denormalized counter for opportunities

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  jobs            Job[]
  opportunities   Opportunity[]

  @@index([organizationType])                    // For gov/NGO/private filtering
  @@index([industry])                              // Already exists conceptually, now explicit
  @@index([county])
  @@map("companies")
}

// ============================================================
// 4. JOBS — Core Job Listings
// ============================================================
// Mobile-first, SEO-optimized. Google Jobs structured data via JSON-LD.
// Salary fields exist but optional (salaryMin, salaryMax, salaryCurrency, salaryPeriod)
// categories is now a JSON array (was single string "category")
// Column naming: mix of camelCase (id, title, slug, ...) and snake_case (is_remote, employment_type, ...)
//
// v2 ADDITIONS:
//   publishedAt    — CRITICAL: Google Jobs requires datePosted
//   featuredImage  — Hero image for featured job cards on homepage
//   industry       — Google Jobs industry field; also powers "Jobs by Industry" filtering
//   viewCount      — Analytics counter (powers "Trending Now" section)
//   applicantCount — Shows "24 applicants" on cards (denormalized from applications count)
//   createdBy      — Admin user who created the job
//
// v2 REMOVALS:
//   applicationUrl, applicationEmail — covered by howToApply
//   source, sourceUrl — replaced by createdBy
//
// NOT added (lives in structured description via markdown template):
//   educationRequirements, skills, qualifications, benefits, experienceDetails
//   → Google reads these from well-structured description headings + bullets

model Job {
  id                  String    @id                   // Primary key (varchar, NOT cuid — set by app/seed)
  title               String                           // "Senior Accountant — Financial Reporting"
  slug                String    @unique                // "senior-accountant-safaricom-2026"
  description         String    @db.LongText           // Full job description (HTML/Markdown)
  categories          Json?                            // JSON array: ["TECHNOLOGY", "FINANCE_ACCOUNTING"]
  shortDescription    String?   @map("short_description") @db.Text  // 2-line excerpt for cards
  featuredImage       String?   @map("featured_image")            // NEW: Hero image URL for featured cards

  // Company
  companyId           String                           // FK to companies.id
  company             Company   @relation(fields: [companyId], references: [id])

  // Location
  country             String?                          // Structured: "Kenya"
  county              String?                          // Structured: "Nairobi" — maps to organizationLocation[].regions[]
  town                String?                          // Specific area/town within county
  isRemote            Boolean   @default(false)  @map("is_remote")

  // Salary
  salaryMin           Int?       @map("salary_min")      // Minimum salary (e.g. 80000)
  salaryMax           Int?       @map("salary_max")      // Maximum salary (e.g. 120000)
  salaryCurrency      String    @default("KES") @map("salary_currency")
  salaryPeriod        String    @default("MONTHLY") @map("salary_period")  // salaryPeriod enum: "HOURLY", "DAILY", "WEEKLY", "MONTHLY", "ANNUALLY"
  isSalaryNegotiable  Boolean   @default(false) @map("is_salary_negotiable")

  // Classification
  employmentType      String    @map("employment_type")  // "FULL_TIME", "PART_TIME", "CONTRACT", "INTERNSHIP", "FREELANCE", "VOLUNTEER"
  experienceLevel     String    @map("experience_level") // "ENTRY_LEVEL", "MID_LEVEL", "SENIOR", "JUNIOR", "LEAD", "MANAGER", "DIRECTOR", "EXECUTIVE"
  industry            String?                              // NEW: "Banking", "Telecommunications", etc.
                                                // Google Jobs industry field + powers "Jobs by Industry" filtering

  // Vacancy
  positions           Int       @default(1)              // Number of open positions

  // Deadline & Application
  applicationDeadline DateTime? @map("application_deadline")
  howToApply          String?   @map("how_to_apply") @db.Text

  // Created by (admin user who posted this job)
  createdBy           String?
  creator             User?     @relation("JobCreator", fields: [createdBy], references: [id])

  // Status
  isFeatured          Boolean   @default(false) @map("is_featured")
  isActive            Boolean   @default(true)  @map("is_active")
  status              String    @default("DRAFT")        // jobStatus enum: "DRAFT", "PUBLISHED", "CLOSED", "ARCHIVED", "FILLED", "EXPIRED"

  // Tags & SEO
  tags                Json?                            // ["tag1", "tag2"]
  metaTitle           String?   @map("meta_title")
  metaDescription     String?   @map("meta_description")

  // Analytics counters
  viewCount           Int       @default(0) @map("view_count")       // NEW: Page views (powers "Trending Now")
  applicantCount      Int       @default(0) @map("applicant_count")  // NEW: Denormalized from applications table

  // Timestamps
  publishedAt         DateTime? @map("published_at")      // NEW: CRITICAL for Google Jobs datePosted
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  savedBy             SavedJob[]
  applications        Application[]

  @@index([employmentType])
  @@index([experienceLevel])
  @@index([companyId])
  @@index([county])
  @@index([isActive])
  @@index([isFeatured])
  @@index([status])
  @@index([country])
  @@index([industry])                                // For industry filtering
  @@index([createdBy])                               // Admin filtering
  @@index([isActive, publishedAt])                   // For "Latest Jobs" sorted by publish date
  @@map("jobs")
}

// ============================================================
// 5. OPPORTUNITIES — Scholarships, Grants, Internships, etc.
// ============================================================
// Similar to jobs but for non-traditional opportunities.
// Types from data.js: 23 opportunity types.
// May be linked to a registered company (optional FK).
//
// v2 ADDITIONS:
//   featuredImage — Hero image for opportunity cards
//   createdBy     — Admin user who created the opportunity
//
// v2 REMOVALS:
//   category (merged into opportunityType), provider, value, currency,
//   targetAudience, fieldOfInterest, source, sourceUrl, externalApplyUrl
//   → All moved to structured description (markdown template)

model Opportunity {
  id                String    @id @default(cuid())
  title             String                               // "Aga Khan Foundation Scholarship 2026"
  slug              String    @unique                    // "aga-khan-foundation-scholarship-2026"
  description       String    @db.LongText               // Full description
  excerpt           String?                              // 2-line excerpt for cards
  featuredImage     String?   @map("featured_image")     // NEW: Hero image URL for cards

  // Company (optional — may not be a registered employer)
  companyId         String?
  company           Company?  @relation(fields: [companyId], references: [id])

  // Classification
  opportunityType   String                               // "SCHOLARSHIP", "GRANT", "FELLOWSHIP", etc.

  // Location
  country           String?                              // Structured: "Kenya"
  county            String?                              // Structured: "Nairobi" — maps to organizationLocation[].regions[]
  town              String?                              // Specific area/town within county
  isRemote          Boolean   @default(false)
  isOnline          Boolean   @default(false)             // For virtual opportunities

  // Deadline & Application
  deadline          DateTime?
  howToApply        String?   @db.Text                   // Rich text instructions

  // Created by (admin user who added this opportunity)
  createdBy         String?
  creator           User?     @relation("OpportunityCreator", fields: [createdBy], references: [id])

  // Tags & SEO
  tags              Json?

  // Status
  status            String    @default("Draft")           // "DRAFT", "PUBLISHED", "CLOSED", "ARCHIVED"
  isFeatured        Boolean   @default(false)
  isActive          Boolean   @default(true)

  // SEO
  noIndex           Boolean   @default(false)
  metaTitle         String?
  metaDescription   String?
  ogImage           String?

  // Analytics
  viewsCount        Int       @default(0)

  // Timestamps
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([opportunityType])
  @@index([companyId])
  @@index([createdBy])
  @@index([isActive, publishedAt])
  @@index([deadline])
  @@index([status])
  @@index([country])
  @@map("opportunities")
}

// ============================================================
// 6. BLOG CATEGORIES
// ============================================================
// 7 categories: CV Writing Tips, Interview Tips, Job Search,
// Career Growth, Government Jobs, Scholarships, Salary & Negotiation

model BlogCategory {
  id              String    @id @default(cuid())
  name            String                               // "CV Writing Tips"
  slug            String    @unique                    // "cv-writing-tips"
  description     String?
  color           String?                              // Theme color
  gradient        String?                              // "var(--primary),#3b82f6"

  // Denormalized counter
  articleCount    Int       @default(0)

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  articles        BlogArticle[]

  @@map("blog_categories")
}

// ============================================================
// 7. BLOG TAGS
// ============================================================
// Tag cloud in sidebars — M:N with articles

model BlogTag {
  id              String    @id @default(cuid())
  name            String                               // "ATS", "CPA-K", "LinkedIn"
  slug            String    @unique                    // "ats"

  // Denormalized counter
  articleCount    Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations (M:N via ArticleTag)
  articleTags     ArticleTag[]

  @@map("blog_tags")
}

// ============================================================
// 8. ARTICLE TAGS — M:N Junction (Article ↔ Tag)
// ============================================================

model ArticleTag {
  articleId       String
  article         BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId           String
  tag             BlogTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

// ============================================================
// 9. BLOG ARTICLES
// ============================================================
// Full articles with rich content, SEO, reactions, views

model BlogArticle {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique                    // "how-to-write-cv-kenya-2026"
  excerpt         String?                              // 2-line excerpt for listing cards
  content         String    @db.LongText               // Full article body (HTML/Markdown)
  featuredImage   String?                              // Hero image URL

  // Author
  authorId        String
  author          Author    @relation(fields: [authorId], references: [id])

  // Category
  categoryId      String
  category        BlogCategory @relation(fields: [categoryId], references: [id])

  // Reading stats
  readingTime     Int       @default(5)                 // Minutes
  viewsCount      Int       @default(0)
  wordCount       Int       @default(0)

  // State
  isFeatured      Boolean   @default(false)             // Featured card on blog listing
  isPublished     Boolean   @default(false)

  // SEO
  noIndex         Boolean   @default(false)
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String?                              // Canonical URL for syndicated content

  // Timestamps
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  tags            ArticleTag[]
  reactions       ArticleReaction[]
  savedBy         SavedArticle[]

  @@index([categoryId])
  @@index([authorId])
  @@index([isPublished, publishedAt])
  @@index([isFeatured])
  @@map("blog_articles")
}

// ============================================================
// 10. AUTHORS — Career Coaches / Writers
// ============================================================
// From blog article prototype: Grace Wanjiku — Senior Career Coach

model Author {
  id              String    @id @default(cuid())
  name            String                               // "Grace Wanjiku"
  slug            String    @unique                    // "grace-wanjiku"
  title           String?                              // "Senior Career Coach"
  bio             String?   @db.Text                    // Bio paragraph for author card
  avatar          String?                              // Avatar URL

  // Social
  twitterUrl      String?
  linkedinUrl     String?

  // Denormalized stats
  articleCount    Int       @default(0)
  totalViews      Int       @default(0)
  peopleCoached   Int       @default(0)

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  articles        BlogArticle[]

  @@map("authors")
}

// ============================================================
// 11. SITE PAGES — CMS for Legal & Info Pages
// ============================================================
// Terms, Privacy, Disclaimer, Cookies, Refunds, About, Contact
// + DPA compliance page (ODPC registration as marketing edge)

model SitePage {
  id              String    @id @default(cuid())
  title           String                               // "Privacy Policy"
  slug            String    @unique                    // "privacy-policy"
  content         String    @db.LongText               // Full HTML content
  metaTitle       String?                              // SEO title
  metaDescription String?

  // Status: "PUBLISHED" | "DRAFT" | "ARCHIVED"
  status          String    @default("DRAFT")

  lastReviewedAt  DateTime?                            // Legal review date

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@map("site_pages")
}

// ============================================================
// 12. FAQS — Frequently Asked Questions
// ============================================================
// Displayed on service pages, legal pages, etc.

model Faq {
  id              String    @id @default(cuid())
  question        String
  answer          String    @db.Text
  category        String?                              // "SERVICES", "PAYMENTS", "PRIVACY", "GENERAL"
  sortOrder       Int       @default(0)
  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category])
  @@map("faqs")
}

// ============================================================
// 13. SAVED JOBS — User Bookmarks
// ============================================================
// Heart/bookmark icon on job cards

model SavedJob {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId           String
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@map("saved_jobs")
}

// ============================================================
// 14. SAVED ARTICLES — User Bookmarks
// ============================================================
// Bookmark icon on article cards

model SavedArticle {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId       String
  article         BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  @@unique([userId, articleId])
  @@index([userId])
  @@map("saved_articles")
}

// ============================================================
// 15. JOB ALERTS — Email Job Alerts
// ============================================================
// "Get new jobs delivered to your inbox daily"
// Seen in: Homepage sidebar, Search Results, Blog sidebars

model JobAlert {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  query           String?                              // "accounting jobs"
  location        String?                              // "Nairobi"
  jobType         String?                              // "FULL_TIME" etc.
  category        String?                              // "TECHNOLOGY" etc.
  isActive        Boolean   @default(true)

  // Email tracking
  lastSentAt      DateTime?
  emailOpenCount  Int       @default(0)
  emailClickCount Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([isActive])
  @@map("job_alerts")
}

// ============================================================
// 16. ARTICLE REACTIONS — Emoji Reactions
// ============================================================
// 👍 Helpful, ❤️ Love it, 💡 Insightful, 🤯 Mind-blowing
// Anonymous users identified by browser fingerprint/cookie

model ArticleReaction {
  id              String    @id @default(cuid())
  articleId       String
  article         BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId          String?                              // null = anonymous
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactionType    String                               // "helpful", "love", "insightful", "mind_blowing"
  fingerprint     String                               // Browser fingerprint (logged-in: userId, anon: cookie hash)
  ipAddress       String?

  createdAt       DateTime  @default(now())

  // One reaction type per fingerprint per article
  @@unique([articleId, fingerprint, reactionType])
  @@index([articleId])
  @@map("article_reactions")
}

// ============================================================
// 17. NOTIFICATIONS — User In-App Notifications
// ============================================================
// Order updates, job alert matches, system messages

model Notification {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            String                               // "ORDER_UPDATE", "JOB_MATCH", "PAYMENT", "SYSTEM"
  title           String
  message         String
  data            Json?                                // {"orderId": "xxx", "status": "CONFIRMED"}
  isRead          Boolean   @default(false)

  createdAt       DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// 18. SERVICE TIERS — Pricing Configuration
// ============================================================
// CV Writing: Basic KSh 500, Professional KSh 1,500, Premium KSh 3,500
// Cover Letter: Basic KSh 500, Premium KSh 1,000
// LinkedIn Profile: Basic KSh 800, Premium KSh 1,500

model ServiceTier {
  id              String    @id @default(cuid())
  serviceType     String                               // "CV_WRITING", "COVER_LETTER", "LINKEDIN_PROFILE"
  tier            String                               // "BASIC", "PROFESSIONAL", "PREMIUM"
  name            String                               // "Professional CV"
  description     String    @db.Text                   // What's included
  price           Int                                  // 500, 1500, 3500
  currency        String    @default("KES")
  features        Json?                                // ["ATS-optimized", "Cover letter included", "LinkedIn review"]
  deliveryDays    Int       @default(3)
  revisionCount   Int       @default(1)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  orderItems      OrderItem[]

  @@unique([serviceType, tier])
  @@index([serviceType])
  @@map("service_tiers")
}

// ============================================================
// 19. ORDERS — Service Orders
// ============================================================
// Revenue engine: Career document service orders
// Nullable userId = walk-in WhatsApp orders (no account)
// Partial payment support via paidAmount/balanceDue

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique                    // "JR-20260404-XXXX"

  // Customer (nullable for walk-in WhatsApp orders)
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  email           String                               // Always required for invoicing
  phone           String                               // Always required
  fullName        String                               // Customer name

  // Status: "PENDING", "CONFIRMED", "IN_PROGRESS", "DELIVERED",
  //         "REVISION", "COMPLETED", "CANCELLED"
  status          String    @default("PENDING")

  // Financials (partial payment support)
  totalAmount     Int                                  // Total in KES
  paidAmount      Int       @default(0)                 // Amount paid so far
  balanceDue      Int                                  // Remaining amount (totalAmount - paidAmount)

  // Payment status: "UNPAID", "PARTIALLY_PAID", "PAID", "REFUNDED"
  paymentStatus   String    @default("UNPAID")

  // Notes
  notes           String?                              // Customer instructions

  // Timestamps
  confirmedAt     DateTime?                            // User confirmed + sent info
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  items           OrderItem[]
  payments        Payment[]
  activities      OrderActivity[]
  attachments     OrderAttachment[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

// ============================================================
// 20. ORDER ITEMS — Line Items per Order
// ============================================================

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  serviceTierId   String
  serviceTier     ServiceTier @relation(fields: [serviceTierId], references: [id])

  serviceName     String                               // "CV Writing" (snapshot at order time)
  tierName        String                               // "Professional" (snapshot)
  price           Int                                  // Unit price
  quantity        Int       @default(1)
  subtotal        Int                                  // price × quantity

  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@map("order_items")
}

// ============================================================
// 21. PAYMENTS — M-Pesa STK Push Payment Records
// ============================================================
// Callback handled by Express server on hosting platform.
// Next.js initiates STK Push, Express server receives callback.
// One order can have multiple payment attempts.

model Payment {
  id                    String    @id @default(cuid())
  orderId               String
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // M-Pesa fields
  checkoutRequestId     String    @unique              // Daraja checkout request ID
  mpesaReceiptNumber    String?   @unique              // "SHK7Y4XB2Z" — actual payment receipt
  phoneNumber           String                               // "254708374149"

  amount                Int                                  // Amount in KES

  // Status: "PENDING", "SUCCESS", "FAILED", "CANCELLED", "TIMEOUT", "REFUNDED"
  status                String    @default("PENDING")
  resultDesc            String?                              // Safaricom result description
  resultCode            String?                              // Safaricom result code

  // Raw M-Pesa callback data (for audit/debug)
  mpesaCallbackData     Json?

  createdAt             DateTime  @default(now())

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

// ============================================================
// 22. ORDER ACTIVITY — Order Status Timeline
// ============================================================
// Tracks every status change for order tracking in dashboard

model OrderActivity {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  action          String                               // "STATUS_CHANGE", "PAYMENT_RECEIVED", "NOTE_ADDED"
  description     String                               // Human-readable description
  metadata        Json?                                // {"from": "PENDING", "to": "CONFIRMED"}

  // Performed by (null = system action)
  performedBy     String?                              // Admin/coach user ID

  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@map("order_activity")
}

// ============================================================
// 23. ORDER ATTACHMENTS — Files on Orders
// ============================================================
// Customer CVs, coach deliverables, revision documents

model OrderAttachment {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fileName        String                               // "cv_senior_accountant.docx"
  filePath        String                               // Server file path
  fileSize        Int?                                 // Bytes
  fileType        String?                              // "application/pdf", "application/vnd.openxmlformats..."

  // Uploaded by (null = customer uploaded via dashboard)
  uploadedBy      String?                              // Admin/coach user ID

  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@map("order_attachments")
}

// ============================================================
// 24. NEWSLETTER SUBSCRIPTIONS
// ============================================================
// "Weekly Career Tips" / "Job Alerts" newsletter forms
// Seen in: Homepage, Blog, Blog Article, Search Results

model NewsletterSubscription {
  id                String     @id @default(cuid())
  email             String     @unique
  userId            String?                                // Link to user if logged in
  user              User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  type              String     @default("career_tips")      // "career_tips" | "job_alerts"

  isActive          Boolean    @default(true)
  subscribedAt      DateTime   @default(now())
  unsubscribedAt    DateTime?

  @@index([isActive])
  @@map("newsletter_subscriptions")
}

// ============================================================
// 25. DATA REQUESTS — DPA Compliance (Kenya Data Protection Act 2019)
// ============================================================
// ODPC registration as marketing advantage
// Types: "ACCESS", "CORRECTION", "DELETION", "OBJECTION", "PORTABILITY"

model DataRequest {
  id                String     @id @default(cuid())
  email             String                                  // Requester email
  requestType       String                                  // "ACCESS", "DELETION", etc.

  // Status: "RECEIVED", "PROCESSING", "COMPLETED", "REJECTED"
  status            String     @default("RECEIVED")

  dataRequested     Json?                                   // Description of what data requested
  processedAt       DateTime?
  responseNote      String?                                 // Admin response

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([email])
  @@index([status])
  @@map("data_requests")
}

// ============================================================
// 26. PAGE VIEWS — Analytics
// ============================================================
// Lightweight page view tracking for stats & popular content

model PageView {
  id              String    @id @default(cuid())
  pageType        String                               // "JOB", "ARTICLE", "COMPANY", "OPPORTUNITY", "HUB", "BLOG"
  pageId          String?                              // Entity ID
  sessionId       String?                              // Browser session ID
  ipAddress       String?
  userAgent       String?
  referer         String?

  createdAt       DateTime  @default(now())

  @@index([pageType, pageId])
  @@index([createdAt])
  @@map("page_views")
}

// ============================================================
// 27. WHATSAPP CLICKS — Analytics
// ============================================================
// Track WhatsApp click-throughs across the site

model WhatsAppClick {
  id              String    @id @default(cuid())
  pageType        String                               // "JOB", "SERVICE", "HOMEPAGE", etc.
  pageId          String?                              // Entity ID
  sessionId       String?                              // Browser session ID
  phoneNumber     String?                              // If known
  context         String?                              // "apply_button", "service_inquiry", "float_button"

  createdAt       DateTime  @default(now())

  @@index([pageType])
  @@index([createdAt])
  @@map("whatsapp_clicks")
}

// ============================================================
// 28. APPLICATIONS — Job Applications
// ============================================================
// Tracks user applications to jobs with status tracking

model Application {
  id              String    @id @default(cuid())
  jobId           String
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Application content
  coverLetter     String?   @db.Text                 // Cover letter text
  cvUrl           String?                              // Uploaded CV file URL

  // Status: "PENDING", "SHORTLISTED", "INTERVIEW", "REJECTED", "HIRED"
  status          String    @default("PENDING")

  // Employer notes
  employerNotes   String?   @db.Text                 // Internal notes from employer

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, jobId])
  @@index([jobId])
  @@index([userId])
  @@index([status])
  @@map("applications")
}

// ============================================================
// 29. AD PLACEMENTS — Ad Management
// ============================================================
// Google AdSense integration

model AdPlacement {
  id              String    @id @default(cuid())
  name            String                               // "Homepage Leaderboard"
  position        String                               // "HOME_TOP", "SIDEBAR_1", "ARTICLE_INLINE"
  adCode          String    @db.MediumText             // AdSense code snippet
  isActive        Boolean   @default(true)

  // Performance tracking
  impressionCount Int       @default(0)
  clickCount      Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([position])
  @@map("ad_placements")
}

// ============================================================
// END OF SCHEMA — 30 TABLES
// ============================================================

