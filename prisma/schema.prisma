// ============================================================
// 1. USERS — Job Seekers
// ============================================================
// Only job seekers register for v1. Admin & employer dashboards
// are separate future projects. Auth handled by NextAuth.js.

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  phone          String?   @unique                    // +2547XXXXXXXX
  googleId       String?   @unique                    // Google OAuth sub (unique identifier)
  name           String
  passwordHash   String?                              // null = OAuth-only user

  // Role
  role           UserRole  @default(JOB_SEEKER)

  // Profile
  avatar         String?                              // Avatar URL or color
  bio            String?                              // Short bio
  location       String?                              // "Nairobi, Kenya"
  linkedinUrl    String?
  education      String?                              // Free text
  skills         Json?                                // ["CPA-K", "Excel", "Sage"]
  cvUrl          String?                              // Uploaded CV path

  // Verification
  emailVerified  Boolean   @default(false)
  phoneVerified  Boolean   @default(false)
  lastLoginAt    DateTime?

  // Timestamps
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  authAccounts   AuthAccount[]
  savedJobs      SavedJob[]
  savedArticles  SavedArticle[]
  jobAlerts      JobAlert[]
  reactions      ArticleReaction[]
  notifications  Notification[]
  orders         Order[]
  newsletterSubs NewsletterSubscription[]
  applications   Application[]

  @@map("users")
}

// ============================================================
// 2. AUTH ACCOUNTS — Multi-provider auth
// ============================================================
// Now only used for: Google OAuth token storage, NextAuth compatibility
// One user can have multiple auth methods linked

model AuthAccount {
  id               String      @id @default(cuid())
  userId           String?
  user             User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         AuthProvider                           // GOOGLE | EMAIL | PHONE
  providerAccountId String     @unique                   // Google sub, phone number, email
  accessToken      String?     @db.Text                    // OAuth token (Google tokens can be very long)
  refreshToken     String?     @db.Text                    // OAuth refresh token
  idToken          String?     @db.Text                    // OpenID token
  expiresAt        DateTime?
  scope            String?     @db.Text                    // OAuth scopes granted
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("auth_accounts")
}

// ============================================================
// 2b. OTPS — One-Time Password Storage
// ============================================================
// Replaces using AuthAccount for OTP. Stores phone OTPs for auth, reset, verify.

model Otp {
  id               String     @id @default(cuid())
  phone            String                       // Target phone number (normalized 2547XXXXXXXX)
  code             String                       // 6-digit OTP
  purpose          OtpPurpose @default(AUTH)    // AUTH | RESET | VERIFY
  verified         Boolean    @default(false)   // Whether this OTP was used
  expiresAt        DateTime                     // OTP expiry time
  createdAt        DateTime   @default(now())

  @@index([phone, purpose])    // For lookup: find latest OTP by phone + purpose
  @@map("otps")
}

// ============================================================
// 3. COMPANIES — Employer Organizations
// ============================================================
// Seen in: Homepage (top employers, trusted bar), Job Detail,
// Company Profile page, Search Results sidebar

model Company {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique                    // "safaricom-plc"
  logo            String?                                        // Logo URL
  logoColor       String?                                        // Fallback gradient "#00a254,#00c853"
  description     String              @db.MediumText             // About section (rich text)

  // Classification
  organizationType OrganizationType?  @map("organization_type")
  industry        OrganizationIndustry                          // 35 industries
  size            CompanySize?                                   // Google Jobs numberOfEmployees

  // Created by (store user ID or email, no relation)
  createdBy       String?

  // Location
  county          String?                                        // "Nairobi"
  town            String?                                        // "Westlands"
  country         String              @default("Kenya")
  website         String?

  // Social links (stored as LongText JSON string)
  socialLinks     String?   @db.LongText                        // [{platform: "LINKEDIN", url: "https://..."}, ...]

  // Public contact
  contactEmail    String?                                        // Public contact email
  phoneNumber     String?                                        // Public phone number

  // Status
  isVerified      Boolean             @default(false)             // Green verified badge
  isFeatured      Boolean             @default(false)             // "Trusted By" section
  isActive        Boolean             @default(true)

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  noIndex         Boolean             @default(false)
  aiMeta          String?             @db.LongText

  // Denormalized counters (updated via triggers/cron)
  jobCount        Int                 @default(0)
  opportunityCount Int                @default(0)

  // Timestamps
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  jobs            Job[]
  opportunities   Opportunity[]

  @@index([organizationType])
  @@index([industry])
  @@index([county])
  @@map("companies")
}

// ============================================================
// 4. JOBS — Core Job Listings
// ============================================================
// Mobile-first, SEO-optimized. Google Jobs structured data via JSON-LD.
// categories is a JSON array (was single string "category")

model Job {
  id                  String              @id @default(cuid())
  title               String                                        // "Senior Accountant — Financial Reporting"
  slug                String              @unique                    // "senior-accountant-safaricom-2026"
  description         String              @db.LongText               // Full job description (HTML/Markdown)
  categories          Json?                                         // JSON array: ["TECHNOLOGY", "FINANCE_ACCOUNTING"]
  shortDescription    String?             @map("short_description") @db.Text
  featuredImage       String?             @map("featured_image")

  // Company
  companyId           String                                        // FK to companies.id
  company             Company             @relation(fields: [companyId], references: [id])

  // Location
  country             String?                                       // "Kenya"
  county              String?                                       // "Nairobi"
  town                String?                                       // Specific area
  isRemote            Boolean             @default(false) @map("is_remote")

  // Salary
  salaryMin           Int?                @map("salary_min")
  salaryMax           Int?                @map("salary_max")
  salaryCurrency      String              @default("KES") @map("salary_currency")
  salaryPeriod        SalaryPeriod        @default(MONTHLY) @map("salary_period")
  isSalaryNegotiable  Boolean             @default(false) @map("is_salary_negotiable")

  // Classification
  employmentType      EmploymentType      @map("employment_type")
  experienceLevel     ExperienceLevel     @map("experience_level")
  industry            OrganizationIndustry?                          // Google Jobs industry + filtering

  // Vacancy
  positions           Int                 @default(1)

  // Deadline & Application
  applicationDeadline DateTime?           @map("application_deadline")
  howToApply          String?             @map("how_to_apply") @db.Text

  // Created by (store user ID or email, no relation)
  createdBy           String?

  // Status
  isFeatured          Boolean             @default(false) @map("is_featured")
  isActive            Boolean             @default(true)  @map("is_active")
  status              JobStatus           @default(DRAFT)

  // Tags & SEO
  tags                Json?                                         // ["tag1", "tag2"]
  metaTitle           String?             @map("meta_title")
  metaDescription     String?             @map("meta_description")
  noIndex             Boolean             @default(false) @map("no_index")
  templateName        String?
  templateId          String?

  // Analytics counters
  viewCount           Int                 @default(0) @map("view_count")
  applicantCount      Int                 @default(0) @map("applicant_count")

  // Timestamps
  publishedAt         DateTime?           @map("published_at")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  savedBy             SavedJob[]
  applications        Application[]

  @@index([employmentType])
  @@index([experienceLevel])
  @@index([companyId])
  @@index([county])
  @@index([isActive])
  @@index([isFeatured])
  @@index([status])
  @@index([country])
  @@index([industry])
  @@index([createdBy])
  @@index([isActive, publishedAt])
  @@map("jobs")
}

// ============================================================
// 5. OPPORTUNITIES — Scholarships, Grants, Internships, etc.
// ============================================================
// Similar to jobs but for non-traditional opportunities.
// 23 opportunity types. Optional FK to Company.

model Opportunity {
  id                String            @id @default(cuid())
  title             String                                      // "Aga Khan Foundation Scholarship 2026"
  slug              String            @unique                    // "aga-khan-foundation-scholarship-2026"
  description       String            @db.LongText               // Full description
  excerpt           String?                                     // 2-line excerpt for cards
  featuredImage     String?           @map("featured_image")

  // Company (optional — may not be a registered employer)
  companyId         String?
  company           Company?          @relation(fields: [companyId], references: [id])

  // Classification
  opportunityType   OpportunityType

  // Deadline & Application
  deadline          DateTime?
  howToApply        String?           @db.Text

  // Created by (store user ID or email, no relation)
  createdBy         String?

  // Tags & SEO
  tags              Json?

  // Status
  status            JobStatus         @default(DRAFT)
  isFeatured        Boolean           @default(false)
  isActive          Boolean           @default(true)

  // SEO
  metaTitle         String?
  metaDescription   String?
  ogImage           String?
  noIndex           Boolean           @default(false)

  // Analytics
  viewCount         Int               @default(0)

  // Timestamps
  publishedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([opportunityType])
  @@index([companyId])
  @@index([createdBy])
  @@index([isActive, publishedAt])
  @@index([deadline])
  @@index([status])
  @@map("opportunities")
}

// ============================================================
// 6. BLOG CATEGORIES
// ============================================================
// 7 categories: CV Writing Tips, Interview Tips, Job Search,
// Career Growth, Government Jobs, Scholarships, Salary & Negotiation

model BlogCategory {
  id              String    @id @default(cuid())
  name            String                               // "CV Writing Tips"
  slug            String    @unique                    // "cv-writing-tips"
  description     String?
  color           String?                              // Theme color
  gradient        String?                              // "var(--primary),#3b82f6"

  // Denormalized counter
  articleCount    Int       @default(0)

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  articles        BlogArticle[]

  @@map("blog_categories")
}

// ============================================================
// 7. BLOG TAGS
// ============================================================
// Tag cloud in sidebars — M:N with articles

model BlogTag {
  id              String    @id @default(cuid())
  name            String                               // "ATS", "CPA-K", "LinkedIn"
  slug            String    @unique                    // "ats"

  // Denormalized counter
  articleCount    Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations (M:N via ArticleTag)
  articleTags     ArticleTag[]

  @@map("blog_tags")
}

// ============================================================
// 8. ARTICLE TAGS — M:N Junction (Article ↔ Tag)
// ============================================================

model ArticleTag {
  articleId       String
  article         BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId           String
  tag             BlogTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

// ============================================================
// 9. BLOG ARTICLES
// ============================================================
// Full articles with rich content, SEO, reactions, views

model BlogArticle {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique                    // "how-to-write-cv-kenya-2026"
  excerpt         String?                              // 2-line excerpt for listing cards
  content         String    @db.LongText               // Full article body (HTML/Markdown)
  featuredImage   String?                              // Hero image URL

  // Author
  authorId        String
  author          Author    @relation(fields: [authorId], references: [id])

  // Category
  categoryId      String
  category        BlogCategory @relation(fields: [categoryId], references: [id])

  // Reading stats
  readingTime     Int       @default(5)
  viewsCount      Int       @default(0)
  wordCount       Int       @default(0)

  // State
  isFeatured      Boolean   @default(false)
  isPublished     Boolean   @default(false)

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String?

  // Timestamps
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  tags            ArticleTag[]
  reactions       ArticleReaction[]
  savedBy         SavedArticle[]

  @@index([categoryId])
  @@index([authorId])
  @@index([isPublished, publishedAt])
  @@index([isFeatured])
  @@map("blog_articles")
}

// ============================================================
// 10. AUTHORS — Career Coaches / Writers
// ============================================================

model Author {
  id              String    @id @default(cuid())
  name            String                               // "Grace Wanjiku"
  slug            String    @unique                    // "grace-wanjiku"
  title           String?                              // "Senior Career Coach"
  bio             String?   @db.Text
  avatar          String?

  // Social
  twitterUrl      String?
  linkedinUrl     String?

  // Denormalized stats
  articleCount    Int       @default(0)
  totalViews      Int       @default(0)
  peopleCoached   Int       @default(0)

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  articles        BlogArticle[]

  @@map("authors")
}

// ============================================================
// 11. SITE PAGES — CMS for Legal & Info Pages
// ============================================================
// Terms, Privacy, Disclaimer, Cookies, Refunds, About, Contact
// + DPA compliance page (ODPC registration as marketing edge)

model SitePage {
  id              String          @id @default(cuid())
  title           String                                    // "Privacy Policy"
  slug            String          @unique                    // "privacy-policy"
  content         String          @db.LongText               // Full HTML content
  metaTitle       String?                                    // SEO title
  metaDescription String?

  // Status
  status          SitePageStatus  @default(DRAFT)

  lastReviewedAt  DateTime?                                  // Legal review date

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@map("site_pages")
}

// ============================================================
// 12. FAQS — Frequently Asked Questions
// ============================================================
// Displayed on service pages, legal pages, etc.

model Faq {
  id              String      @id @default(cuid())
  question        String
  answer          String      @db.Text
  category        FaqCategory?
  sortOrder       Int         @default(0)
  isActive        Boolean     @default(true)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([category])
  @@map("faqs")
}

// ============================================================
// 13. SAVED JOBS — User Bookmarks
// ============================================================

model SavedJob {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId           String
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@map("saved_jobs")
}

// ============================================================
// 14. SAVED ARTICLES — User Bookmarks
// ============================================================

model SavedArticle {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId       String
  article         BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())

  @@unique([userId, articleId])
  @@index([userId])
  @@map("saved_articles")
}

// ============================================================
// 15. JOB ALERTS — Email Job Alerts
// ============================================================
// "Get new jobs delivered to your inbox daily"
// Seen in: Homepage sidebar, Search Results, Blog sidebars

model JobAlert {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  query           String?                                   // "accounting jobs"
  location        String?                                   // "Nairobi"
  jobType         EmploymentType?                            // FULL_TIME, PART_TIME, etc.
  category        String?                                   // Free-form category (26 job categories)
  isActive        Boolean         @default(true)

  // Email tracking
  lastSentAt      DateTime?
  emailOpenCount  Int             @default(0)
  emailClickCount Int             @default(0)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([isActive])
  @@map("job_alerts")
}

// ============================================================
// 16. ARTICLE REACTIONS — Emoji Reactions
// ============================================================
// HELPFUL, LOVE, INSIGHTFUL, MIND_BLOWING
// Anonymous users identified by browser fingerprint/cookie

model ArticleReaction {
  id              String       @id @default(cuid())
  articleId       String
  article         BlogArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId          String?                                  // null = anonymous
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactionType    ReactionType
  fingerprint     String                                  // Browser fingerprint
  ipAddress       String?

  createdAt       DateTime     @default(now())

  // One reaction type per fingerprint per article
  @@unique([articleId, fingerprint, reactionType])
  @@index([articleId])
  @@map("article_reactions")
}

// ============================================================
// 17. NOTIFICATIONS — User In-App Notifications
// ============================================================
// Order updates, job alert matches, system messages

model Notification {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            NotificationType
  title           String
  message         String
  data            Json?                                   // {"orderId": "xxx", "status": "CONFIRMED"}
  isRead          Boolean         @default(false)

  createdAt       DateTime        @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// 18. SERVICE TIERS — Pricing Configuration
// ============================================================
// CV Writing: Basic KSh 500, Professional KSh 1,500, Premium KSh 3,500
// Cover Letter: Basic KSh 500, Premium KSh 1,000
// LinkedIn Profile: Basic KSh 800, Premium KSh 1,500

model ServiceTier {
  id              String          @id @default(cuid())
  serviceType     ServiceType
  tier            ServiceTierLevel
  name            String                                    // "Professional CV"
  description     String          @db.Text                  // What's included
  price           Int                                      // 500, 1500, 3500
  currency        String          @default("KES")
  features        Json?                                     // ["ATS-optimized", "Cover letter included", ...]
  deliveryDays    Int             @default(3)
  revisionCount   Int             @default(1)
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  orderItems      OrderItem[]

  @@unique([serviceType, tier])
  @@index([serviceType])
  @@map("service_tiers")
}

// ============================================================
// 19. ORDERS — Service Orders
// ============================================================
// Revenue engine: Career document service orders
// Nullable userId = walk-in WhatsApp orders (no account)
// Partial payment support via paidAmount/balanceDue

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique                    // "JR-20260404-XXXX"

  // Customer (nullable for walk-in WhatsApp orders)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  email           String                                   // Always required for invoicing
  phone           String                                   // Always required
  fullName        String                                   // Customer name

  // Status
  status          OrderStatus   @default(PENDING)

  // Financials (partial payment support)
  totalAmount     Int                                      // Total in KES
  paidAmount      Int           @default(0)                 // Amount paid so far
  balanceDue      Int                                      // Remaining amount (totalAmount - paidAmount)

  // Payment status
  paymentStatus   PaymentStatus @default(UNPAID)

  // Notes
  notes           String?                                  // Customer instructions

  // Timestamps
  confirmedAt     DateTime?                                // User confirmed + sent info
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  items           OrderItem[]
  payments        Payment[]
  activities      OrderActivity[]
  attachments     OrderAttachment[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

// ============================================================
// 20. ORDER ITEMS — Line Items per Order
// ============================================================

model OrderItem {
  id              String      @id @default(cuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  serviceTierId   String
  serviceTier     ServiceTier @relation(fields: [serviceTierId], references: [id])

  serviceName     String                                // "CV Writing" (snapshot at order time)
  tierName        String                                // "Professional" (snapshot)
  price           Int                                   // Unit price
  quantity        Int         @default(1)
  subtotal        Int                                   // price × quantity

  createdAt       DateTime    @default(now())

  @@index([orderId])
  @@map("order_items")
}

// ============================================================
// 21. PAYMENTS — M-Pesa STK Push Payment Records
// ============================================================
// Callback handled by Express server on hosting platform.
// One order can have multiple payment attempts.

model Payment {
  id                    String             @id @default(cuid())
  orderId               String?
  order                 Order?             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  companyId             String?

  // Payment type & description
  type                  String             @default("ORDER")
  description           String?

  // M-Pesa fields
  checkoutRequestId     String             @unique              // Daraja checkout request ID
  mpesaReceiptNumber    String?            @unique              // "SHK7Y4XB2Z"
  phoneNumber           String                                  // "254708374149"

  amount                Int                                     // Amount in KES

  // Status
  status                MpesaPaymentStatus @default(PENDING)
  resultDesc            String?                                 // Safaricom result description
  resultCode            String?                                 // Safaricom result code

  // Raw M-Pesa callback data (for audit/debug)
  mpesaCallbackData     Json?

  createdAt             DateTime           @default(now())

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

// ============================================================
// 22. ORDER ACTIVITY — Order Status Timeline
// ============================================================
// Tracks every status change for order tracking in dashboard

model OrderActivity {
  id              String              @id @default(cuid())
  orderId         String
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  action          OrderActivityAction
  description     String                                      // Human-readable description
  metadata        Json?                                       // {"from": "PENDING", "to": "CONFIRMED"}

  // Performed by (null = system action)
  performedBy     String?                                     // Admin/coach user ID

  createdAt       DateTime            @default(now())

  @@index([orderId])
  @@map("order_activity")
}

// ============================================================
// 23. ORDER ATTACHMENTS — Files on Orders
// ============================================================
// Customer CVs, coach deliverables, revision documents

model OrderAttachment {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fileName        String                               // "cv_senior_accountant.docx"
  filePath        String                               // Server file path
  fileSize        Int?                                 // Bytes
  fileType        String?                              // MIME type

  // Uploaded by (null = customer uploaded via dashboard)
  uploadedBy      String?                              // Admin/coach user ID

  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@map("order_attachments")
}

// ============================================================
// 24. NEWSLETTER SUBSCRIPTIONS
// ============================================================
// "Weekly Career Tips" / "Job Alerts" newsletter forms

model NewsletterSubscription {
  id                String         @id @default(cuid())
  email             String         @unique
  userId            String?                                // Link to user if logged in
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  type              NewsletterType @default(CAREER_TIPS)

  isActive          Boolean        @default(true)
  subscribedAt      DateTime       @default(now())
  unsubscribedAt    DateTime?

  @@index([isActive])
  @@map("newsletter_subscriptions")
}

// ============================================================
// 25. DATA REQUESTS — DPA Compliance (Kenya Data Protection Act 2019)
// ============================================================
// ODPC registration as marketing advantage

model DataRequest {
  id                String            @id @default(cuid())
  email             String                                    // Requester email
  requestType       DataRequestType

  // Status
  status            DataRequestStatus @default(RECEIVED)

  dataRequested     Json?                                     // Description of what data requested
  processedAt       DateTime?
  responseNote      String?                                   // Admin response

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([email])
  @@index([status])
  @@map("data_requests")
}

// ============================================================
// 26. PAGE VIEWS — Analytics
// ============================================================
// Lightweight page view tracking for stats & popular content

model PageView {
  id              String    @id @default(cuid())
  pageType        PageType
  pageId          String?                              // Entity ID
  sessionId       String?                              // Browser session ID
  ipAddress       String?
  userAgent       String?
  referer         String?

  createdAt       DateTime  @default(now())

  @@index([pageType, pageId])
  @@index([createdAt])
  @@map("page_views")
}

// ============================================================
// 27. WHATSAPP CLICKS — Analytics
// ============================================================
// Track WhatsApp click-throughs across the site

model WhatsAppClick {
  id              String            @id @default(cuid())
  pageType        WhatsAppPageType
  pageId          String?                                // Entity ID
  sessionId       String?                                // Browser session ID
  phoneNumber     String?                                // If known
  context         WhatsAppContext?

  createdAt       DateTime          @default(now())

  @@index([pageType])
  @@index([createdAt])
  @@map("whatsapp_clicks")
}

// ============================================================
// 28. APPLICATIONS — Job Applications
// ============================================================
// Tracks user applications to jobs with status tracking

model Application {
  id              String            @id @default(cuid())
  jobId           String
  job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Application content
  coverLetter     String?           @db.Text                 // Cover letter text
  cvUrl           String?                                     // Uploaded CV file URL

  // Status
  status          ApplicationStatus @default(PENDING)

  // Employer notes
  employerNotes   String?           @db.Text                 // Internal notes from employer

  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId, jobId])
  @@index([jobId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([status])
  @@map("applications")
}

// ============================================================
// 29. AD PLACEMENTS — Ad Management
// ============================================================
// Google AdSense integration

model AdPlacement {
  id              String      @id @default(cuid())
  name            String                                // "Homepage Leaderboard"
  position        AdPosition
  adCode          String      @db.MediumText             // AdSense code snippet
  isActive        Boolean     @default(true)

  // Performance tracking
  impressionCount Int         @default(0)
  clickCount      Int         @default(0)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([position])
  @@map("ad_placements")
}

// ============================================================
// END OF SCHEMA — 30 TABLES + 29 ENUMS
// ============================================================

